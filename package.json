{
  "name": "bkg-oc-plugin-bkg-dfma",
  "version": "0.1.0",
  "description": "BKG OpenCode plugin pack with background agents, rules, Agent Rat, dashboard review gates, sync, memory and BitShit adapter APIs.",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eyshoit-commits/opencode.git"
  },
  "files": [
    "dist",
    "assets",
    "scripts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "lint:readme": "node scripts/lint-readme.mjs",
    "lint:lockfile": "node scripts/assert-lockfile.mjs",
    "ci": "npm run lint:readme && npm run lint:lockfile && npm run typecheck && npm run test && npm run build && npm pack --dry-run",
    "install:assets": "tsx scripts/install-assets.ts",
    "dashboard:start": "tsx src/dashboard/server.ts"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.17.15",
    "@opencode-ai/sdk": "^1.17.15"
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.2.4"
  },
  "license": "MIT"
}
