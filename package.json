{
  "name": "bkg-oc-plugin-stop-4uck-m3-agen1s",
  "version": "0.1.0",
  "description": "BKG OpenCode plugin pack with background agents, six-main workflow assets, Agent Rat and vote skills.",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
